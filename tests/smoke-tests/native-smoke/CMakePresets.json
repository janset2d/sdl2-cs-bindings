{
  "version": 3,
  "configurePresets": [
    {
      "name": "vcpkg-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/../../../external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": "OFF",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/../../../vcpkg_installed",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/../../../vcpkg-overlay-triplets"
      }
    },

    {
      "name": "win-x64-base",
      "hidden": true,
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x64-windows-hybrid" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "win-x64",
      "inherits": "win-x64-base",
      "displayName": "Windows x64 (Release)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "win-x64-debug",
      "inherits": "win-x64-base",
      "displayName": "Windows x64 (Debug)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },

    {
      "name": "win-x86-base",
      "hidden": true,
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x86-windows-hybrid" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "win-x86",
      "inherits": "win-x86-base",
      "displayName": "Windows x86 (Release)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "win-x86-debug",
      "inherits": "win-x86-base",
      "displayName": "Windows x86 (Debug)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },

    {
      "name": "win-arm64-base",
      "hidden": true,
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "arm64-windows-hybrid" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "win-arm64",
      "inherits": "win-arm64-base",
      "displayName": "Windows arm64 (Release)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "win-arm64-debug",
      "inherits": "win-arm64-base",
      "displayName": "Windows arm64 (Debug)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },

    {
      "name": "linux-x64-base",
      "hidden": true,
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x64-linux-hybrid" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "linux-x64",
      "inherits": "linux-x64-base",
      "displayName": "Linux x64 (Release)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "linux-x64-debug",
      "inherits": "linux-x64-base",
      "displayName": "Linux x64 (Debug)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },

    {
      "name": "linux-arm64-base",
      "hidden": true,
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "arm64-linux-hybrid" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "linux-arm64",
      "inherits": "linux-arm64-base",
      "displayName": "Linux arm64 (Release)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "linux-arm64-debug",
      "inherits": "linux-arm64-base",
      "displayName": "Linux arm64 (Debug)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },

    {
      "name": "osx-x64-base",
      "hidden": true,
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x64-osx-hybrid" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    },
    {
      "name": "osx-x64",
      "inherits": "osx-x64-base",
      "displayName": "macOS x64 (Release)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "osx-x64-debug",
      "inherits": "osx-x64-base",
      "displayName": "macOS x64 (Debug)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },

    {
      "name": "osx-arm64-base",
      "hidden": true,
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "arm64-osx-hybrid" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    },
    {
      "name": "osx-arm64",
      "inherits": "osx-arm64-base",
      "displayName": "macOS arm64 (Release)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "osx-arm64-debug",
      "inherits": "osx-arm64-base",
      "displayName": "macOS arm64 (Debug)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    }
  ],
  "buildPresets": [
    { "name": "win-x64",          "configurePreset": "win-x64" },
    { "name": "win-x64-debug",    "configurePreset": "win-x64-debug" },
    { "name": "win-x86",          "configurePreset": "win-x86" },
    { "name": "win-x86-debug",    "configurePreset": "win-x86-debug" },
    { "name": "win-arm64",        "configurePreset": "win-arm64" },
    { "name": "win-arm64-debug",  "configurePreset": "win-arm64-debug" },
    { "name": "linux-x64",        "configurePreset": "linux-x64" },
    { "name": "linux-x64-debug",  "configurePreset": "linux-x64-debug" },
    { "name": "linux-arm64",      "configurePreset": "linux-arm64" },
    { "name": "linux-arm64-debug", "configurePreset": "linux-arm64-debug" },
    { "name": "osx-x64",          "configurePreset": "osx-x64" },
    { "name": "osx-x64-debug",    "configurePreset": "osx-x64-debug" },
    { "name": "osx-arm64",        "configurePreset": "osx-arm64" },
    { "name": "osx-arm64-debug",  "configurePreset": "osx-arm64-debug" }
  ]
}
