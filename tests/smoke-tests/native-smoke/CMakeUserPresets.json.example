{
  "version": 3,
  "configurePresets": [
    {
      "name": "win-x64-interactive",
      "inherits": "win-x64-debug",
      "displayName": "Windows x64 (Interactive — local override)",
      "cacheVariables": { "SMOKE_INTERACTIVE": "ON" }
    },
    {
      "name": "win-x86-interactive",
      "inherits": "win-x86-debug",
      "displayName": "Windows x86 (Interactive — local override)",
      "cacheVariables": { "SMOKE_INTERACTIVE": "ON" }
    },
    {
      "name": "win-arm64-interactive",
      "inherits": "win-arm64-debug",
      "displayName": "Windows arm64 (Interactive — local override)",
      "cacheVariables": { "SMOKE_INTERACTIVE": "ON" }
    },
    {
      "name": "linux-x64-interactive",
      "inherits": "linux-x64-debug",
      "displayName": "Linux x64 (Interactive — local override)",
      "cacheVariables": { "SMOKE_INTERACTIVE": "ON" }
    },
    {
      "name": "linux-arm64-interactive",
      "inherits": "linux-arm64-debug",
      "displayName": "Linux arm64 (Interactive — local override)",
      "cacheVariables": { "SMOKE_INTERACTIVE": "ON" }
    },
    {
      "name": "osx-x64-interactive",
      "inherits": "osx-x64-debug",
      "displayName": "macOS x64 (Interactive — local override)",
      "cacheVariables": { "SMOKE_INTERACTIVE": "ON" }
    },
    {
      "name": "osx-arm64-interactive",
      "inherits": "osx-arm64-debug",
      "displayName": "macOS arm64 (Interactive — local override)",
      "cacheVariables": { "SMOKE_INTERACTIVE": "ON" }
    }
  ],
  "buildPresets": [
    { "name": "win-x64-interactive",     "configurePreset": "win-x64-interactive" },
    { "name": "win-x86-interactive",     "configurePreset": "win-x86-interactive" },
    { "name": "win-arm64-interactive",   "configurePreset": "win-arm64-interactive" },
    { "name": "linux-x64-interactive",   "configurePreset": "linux-x64-interactive" },
    { "name": "linux-arm64-interactive", "configurePreset": "linux-arm64-interactive" },
    { "name": "osx-x64-interactive",     "configurePreset": "osx-x64-interactive" },
    { "name": "osx-arm64-interactive",   "configurePreset": "osx-arm64-interactive" }
  ]
}
