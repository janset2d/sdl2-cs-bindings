diff --git a/ports/cmake/src/CMakeLists.txt b/ports/cmake/src/CMakeLists.txt
index f6a77b9..b3e8f21 100644
--- a/ports/cmake/src/CMakeLists.txt
+++ b/ports/cmake/src/CMakeLists.txt
@@ -196,8 +196,14 @@ check_cpu_arch_x64(ARCH_IS_X64)
 check_cpu_arch_arm32(ARCH_IS_ARM32)
 check_cpu_arch_arm64(ARCH_IS_ARM64)

-if(WIN32 OR (ARCH_IS_ARM64 AND APPLE))
+# Overlay fix: force HAVE_FPU=1 on arm64 Linux.
+# Native arm64 Linux builds incorrectly report no FPU in container
+# environments, causing REAL_IS_FIXED + OPT_NEON64 conflict.
+# The original condition only covered Windows and Apple arm64.
+# Upstream: microsoft/vcpkg#40709
+if(WIN32 OR (ARCH_IS_ARM64 AND APPLE) OR (ARCH_IS_ARM64 AND LINUX))
     set(HAVE_FPU 1)
+elseif(CMAKE_CROSSCOMPILING OR DEFINED HAVE_FPU)
+    set(HAVE_FPU 1 CACHE STRING "Override in triplet if needed")
 else()
     cmake_host_system_information(RESULT HAVE_FPU QUERY HAS_FPU)
 endif()
