<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Build host tests are single-TFM; track $(LatestDotNet) from root Directory.Build.props. -->
    <TargetFramework>$(LatestDotNet)</TargetFramework>
    <TargetFrameworks></TargetFrameworks>
    <OutputType>Exe</OutputType>
    <IsTestProject>true</IsTestProject>
    <RootNamespace>Build.Tests</RootNamespace>
    <AssemblyName>Build.Tests</AssemblyName>
    <NoWarn>$(NoWarn);CA1050;CA1515;CA1707;CA1806;CA2007;MA0045;MA0047;MA0051;S4144;S2699</NoWarn>
    <NoError>$(NoError);CA1050;CA1515;CA1707;CA1806;CA2007;MA0045;MA0047;MA0051;S4144;S2699</NoError>
    <IsAotCompatible>false</IsAotCompatible>
    <IsTrimmable>false</IsTrimmable>
    <EnableAOTAnalyzer>false</EnableAOTAnalyzer>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\_build\Build.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="TUnit" />
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="Cake.Testing" />
  </ItemGroup>
</Project>
