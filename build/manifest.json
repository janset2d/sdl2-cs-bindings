        { "os": "OSX", "patterns": ["libSDL2_gfx*.dylib"] }
      ]
    },
    {
      "name": "SDL2_net",
      "vcpkg_name": "sdl2-net",
      "vcpkg_version": "2.2.0",
      "vcpkg_port_version": 3,
      "native_lib_name": "SDL2.Net.Native",
