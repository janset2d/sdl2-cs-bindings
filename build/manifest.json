        { "os": "OSX", "patterns": ["libSDL2_image*.dylib"] }
      ]
    },
    {
      "name": "SDL2_mixer",
      "vcpkg_name": "sdl2-mixer",
      "vcpkg_version": "2.8.1",
      "vcpkg_port_version": 2,
      "native_lib_name": "SDL2.Mixer.Native",
      "core_lib": false,
